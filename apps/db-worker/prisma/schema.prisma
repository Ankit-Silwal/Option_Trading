
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Trade{
  id Int @id @default(autoincrement())
  orderId String @unique
  userId Int
  symbol String
  side String
  price Float
  quantity Float
  status String
  created_at DateTime @default(now())
}